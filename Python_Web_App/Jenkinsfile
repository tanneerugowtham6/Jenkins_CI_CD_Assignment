pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo 'Installing the dependencies...'
                sh '''
                python3 -m venv venv
                . venv/bin/activate
                cd Python_Web_App/
                pip install -r requirements.txt
                '''
            }
        }
        stage('Test') {
            steps {
                echo 'Testing the application...'
                sh '''
                . venv/bin/activate
                cd Python_Web_App/
                pytest || true
                '''
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying the application...'
                sh '''
                . venv/bin/activate
                cd Python_Web_App/
                python3 app.py
                '''
            }
        }
    }
}